{
  "name": "turboref",
  "version": "0.1.0",
  "description": "Pandoc-crossref compatible Obsidian plugin with Rust/WASM core",
  "main": "main.js",
  "scripts": {
    "build:wasm": "wasm-pack build crates/wasm --target web --release",
    "build:ts": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "build": "npm run build:wasm && npm run build:ts",
    "dev:wasm": "cargo watch -w crates -s 'npm run build:wasm'",
    "dev:ts": "node esbuild.config.mjs",
    "dev": "concurrently 'npm run dev:wasm' 'npm run dev:ts'",
    "test": "cargo test -p turboref-core && vitest run",
    "test:ts": "vitest run",
    "test:rust": "cargo test -p turboref-core",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "release": "node scripts/release.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "@typescript-eslint/eslint-plugin": "5.29.0",
    "@typescript-eslint/parser": "5.29.0",
    "builtin-modules": "3.3.0",
    "concurrently": "^8.0.0",
    "esbuild": "0.17.3",
    "jsdom": "^29.0.2",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "4.7.4",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@codemirror/language": "^6.10.8",
    "ioredis": "^5.10.1"
  }
}
